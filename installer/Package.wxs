<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <Package Name="AirLift"
           Manufacturer="AirLift"
           Version="1.0.0"
           UpgradeCode="74e49a22-2f83-48a2-9584-ccf058cfc530"
           Scope="perMachine"
           Language="1033"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of AirLift is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="AirLift">
        <Component Id="MainExe">
          <File Id="AirLiftExe" Source="publish\AirLift.exe" KeyPath="yes">
            <!-- Inbound UDP allow: the receiver sends NTP timing requests and
                 retransmit requests to the sender's ephemeral UDP ports -->
            <fw:FirewallException Id="FwUdpIn"
                                  Name="AirLift (AirPlay timing/control)"
                                  Protocol="udp"
                                  Scope="any"
                                  IgnoreFailure="yes" />
          </File>
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut">
        <Shortcut Id="AppShortcut"
                  Name="AirLift"
                  Description="Stream Windows audio to AirPlay speakers"
                  Target="[INSTALLFOLDER]AirLift.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\AirLift" Name="installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="AirLift" Level="1">
      <ComponentRef Id="MainExe" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>
</Wix>
